# Local .terraform directories
**/.terraform/*

# Terraform lock file (optional: some teams commit this)
# .terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files (may contain secrets)
*.tfplan

# CLI config
.terraformrc
terraform.rc

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/  